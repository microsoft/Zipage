{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            // 添加环境变量
            "env": {
                "CUDA_VISIBLE_DEVICES": "0",
                "PYTHONHASHSEED": "0",
                "NANOVLLM_LOG_LEVEL": "INFO",
                "HF_HOME": "/local_nvme/liaomengqi/hugingface",
                "TORCH_EXTENSIONS_DIR": "/local_nvme/.cache/torch_extensions",
                "VLLM_CACHE_ROOT": "/local_nvme/.cache/vllm",
                "TRITON_CACHE_DIR": "/local_nvme/.cache/triton",
                "TORCH_COMPILE_DEBUG_DIR": "/local_nvme/.cache/torch_compile",
                "TEMP": "/local_nvme/tmp"
            }
        }
    ]
}